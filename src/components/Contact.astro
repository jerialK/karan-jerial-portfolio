---
---

<section class="contact section" id="contact" aria-label="Contact">
  <div class="container contact__inner">

    <div class="contact__left">
      <p class="section-eyebrow fade-in">Contact</p>
      <h2 class="contact__heading fade-in fade-in-delay-1">Let's talk.</h2>
      <p class="contact__sub fade-in fade-in-delay-2">
        Open to operations, supply chain, procurement, and analytics opportunities.
        Reach out by email or LinkedIn — I respond quickly and directly.
      </p>
      <div class="contact__links fade-in fade-in-delay-3">
        <a
          href="https://www.linkedin.com/in/karan-veer-singh-jerial-b1340216a"
          target="_blank"
          rel="noopener noreferrer"
          class="contact__social-link"
        >
          <span class="label">LinkedIn</span>
          <span class="contact__arrow">↗</span>
        </a>
        <a id="contact-email-link" href="#" class="contact__social-link">
          <span class="label" id="contact-email-text">Email</span>
          <span class="contact__arrow">↗</span>
        </a>
      </div>
    </div>

    <div class="contact__form-wrap fade-in fade-in-delay-2">
      <form
        id="contact-form"
        class="contact__form"
        method="POST"
        action="https://formspree.io/f/mdaynvwg"
        novalidate
      >
        <div class="form-field">
          <label class="form-label eyebrow" for="cf-name">Name</label>
          <input type="text" id="cf-name" name="name" class="form-input"
                 placeholder="Your name" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label class="form-label eyebrow" for="cf-email">Email</label>
          <input type="email" id="cf-email" name="email" class="form-input"
                 placeholder="you@company.com" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label class="form-label eyebrow" for="cf-message">Message</label>
          <textarea id="cf-message" name="message" class="form-input form-textarea"
                    placeholder="Tell me about the opportunity..." required rows="5"></textarea>
        </div>
        <button type="submit" class="form-submit" id="form-submit-btn">
          <span id="form-submit-label">Send message</span>
          <svg id="form-spinner" class="form-spinner" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
          </svg>
        </button>
        <p id="form-success" class="form-success" style="display:none" role="alert">
          Message sent. I will get back to you soon.
        </p>
        <p id="form-error" class="form-error" style="display:none" role="alert">
          Something went wrong. Please try emailing me directly.
        </p>
      </form>
    </div>

  </div>
</section>

<script>
  (function () {
    const u = 'jerial.k'; const d = 'northeastern.edu';
    const link = document.getElementById('contact-email-link') as HTMLAnchorElement | null;
    const text = document.getElementById('contact-email-text');
    if (link && text) {
      const addr = u + '@' + d;
      text.textContent = addr;
      link.setAttribute('href', 'mailto:' + addr);
    }
  })();

  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn     = document.getElementById('form-submit-btn') as HTMLButtonElement | null;
  const label   = document.getElementById('form-submit-label');
  const spinner = document.getElementById('form-spinner') as HTMLElement | null;
  const success = document.getElementById('form-success') as HTMLElement | null;
  const error   = document.getElementById('form-error') as HTMLElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn || !label || !spinner || !success || !error) return;
      btn.disabled = true;
      label.textContent = 'Sending…';
      spinner.style.display = 'block';
      success.style.display = 'none';
      error.style.display   = 'none';
      try {
        const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
        if (res.ok) {
          form.reset();
          success.style.display = 'block';
          label.textContent = 'Send message';
        } else {
          error.style.display = 'block';
          label.textContent = 'Send message';
        }
      } catch {
        error.style.display = 'block';
        label.textContent = 'Send message';
      } finally {
        btn.disabled = false;
        spinner.style.display = 'none';
      }
    });
  }
</script>

<style>
.contact {
  background: var(--color-surface);
}

.contact__inner {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: clamp(2.5rem, 8vw, 6rem);
  align-items: start;
}
@media (max-width: 800px) {
  .contact__inner { grid-template-columns: 1fr; }
}

/* ── Left ───────────────────────────────────────────────────────── */
.contact__heading {
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 300;
  font-style: italic;
  letter-spacing: -0.04em;
  line-height: 1.05;
  margin-block: var(--space-sm) var(--space-md);
}

.contact__sub {
  font-size: 0.95rem;
  color: var(--color-muted);
  line-height: 1.85;
  max-width: 40ch;
  margin-bottom: var(--space-lg);
}

.contact__links {
  display: flex;
  flex-direction: column;
  border-top: 1px solid var(--color-border);
}

.contact__social-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-block: var(--space-md);
  border-bottom: 1px solid var(--color-border);
  transition: color var(--transition-fast);
}
.contact__social-link:hover { color: var(--color-signal); }
.contact__social-link:hover .label { color: var(--color-signal); }

.contact__arrow {
  font-size: 0.85rem;
  color: var(--color-border);
}

/* ── Form ───────────────────────────────────────────────────────── */
.contact__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-label { display: block; font-size: 0.62rem; letter-spacing: 0.14em; }

.form-input {
  width: 100%;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0.75em 1em;
  font-family: var(--font-body);
  font-size: 0.88rem;
  color: var(--color-text);
  line-height: 1.5;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  outline: none;
  appearance: none;
}
.form-input::placeholder { color: var(--color-border); }
.form-input:focus {
  border-color: var(--color-muted);
  box-shadow: 0 0 0 3px rgba(138,125,110,0.1);
}
.form-textarea { resize: vertical; min-height: 130px; }

.form-submit {
  display: inline-flex;
  align-items: center;
  gap: 0.6em;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: var(--weight-medium);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.85em 1.75em;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-text);
  background: var(--color-text);
  color: var(--color-bg);
  cursor: pointer;
  align-self: flex-start;
  transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
}
.form-submit:hover:not(:disabled) { opacity: 0.82; transform: translateY(-1px); }
.form-submit:disabled { opacity: 0.55; cursor: not-allowed; }

@keyframes spin { to { transform: rotate(360deg); } }
.form-spinner { animation: spin 0.8s linear infinite; }

.form-success {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: #3a6644;
  background: rgba(58,102,68,0.08);
  border: 1px solid rgba(58,102,68,0.25);
  border-radius: var(--radius-sm);
  padding: 0.75em 1em;
}
.form-error {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: #8a3a2a;
  background: rgba(138,58,42,0.08);
  border: 1px solid rgba(138,58,42,0.25);
  border-radius: var(--radius-sm);
  padding: 0.75em 1em;
}
</style>
