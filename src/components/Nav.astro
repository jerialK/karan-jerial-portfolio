---
const links = [
  { href: '#home',       label: 'Home' },
  { href: '#about',      label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects',   label: 'Projects' },
  { href: '#skills',     label: 'Skills' },
  { href: '#contact',    label: 'Contact' },
];
---

<nav class="nav" aria-label="Main navigation">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">Karan Jerial</a>
    <div class="nav__right">
      <ul class="nav__links" role="list">
        {links.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
      <div class="nav__social-icons">
        <a
          href="https://www.linkedin.com/in/karan-veer-singh-jerial-b1340216a"
          target="_blank"
          rel="noopener noreferrer"
          class="nav__social-link"
          aria-label="LinkedIn profile"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a
          href="https://github.com/jerialK"
          target="_blank"
          rel="noopener noreferrer"
          class="nav__social-link"
          aria-label="GitHub profile"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
      </div>
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle dark mode"
        type="button"
      >
        <!-- Sun (shown in dark mode) -->
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1"  x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22"  x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1"  y1="12" x2="3"  y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<style>
.nav__right {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.nav__social-icons {
  display: flex;
  align-items: center;
  gap: 14px;
}

.nav__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  transition: color var(--transition-fast);
}
.nav__social-link:hover {
  color: var(--color-accent);
}

@media (max-width: 680px) {
  .nav__social-icons { display: none; }
}
</style>
